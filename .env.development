# 项目环境
NODE_ENV = development
# 项目启动端口号
PORT = 3001
# PostgreSql 本地链接地址
DB_HOST = localhost
# PostgreSql 端口号
DB_PORT = 5432
# 数据库用户名
DB_USERNAME = jiao
# 数据库密码，如果没有密码，不用填写值
DB_PASSWORD = 
# 数据库名称
DB_DATABASE = blog
# 开启日志
DB_OPEN_LOG = true
# 默认用户名
DEFAULT_USERNAME = dogegg
# 默认密码
DEFAULT_PASSWORD = dogegg
# Redis 本地链接地址
REDIS_HOST = localhost
# Redis 端口号
REDIS_PORT = 6379
# Redis 密码
REDIS_PASSWORD = 
# Redis 数据库
REDIS_DB = 0
